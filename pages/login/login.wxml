<view class="login-container">
  <view class="logo-section">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="app-title">校园外卖</text>
    <text class="app-subtitle">美味直达，便捷生活</text>
  </view>

  <view class="login-section">
    <button class="btn-primary login-btn" bindtap="onLogin" loading="{{loading}}">
      <text class="btn-text">微信一键登录</text>
    </button>
    
    <view class="rider-section">
      <text class="rider-text">想成为骑手？</text>
      <button class="btn-secondary rider-btn" bindtap="onRiderRegister">
        <text class="btn-text">我要成为骑手</text>
      </button>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">登录即表示同意</text>
    <view class="footer-links">
      <text class="link-text" bindtap="onServiceTerms">服务条款</text>
      <text class="footer-text">和</text>
      <text class="link-text" bindtap="onPrivacyPolicy">隐私政策</text>
    </view>
  </view>

  <!-- 加载动画 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">登录中...</text>
    </view>
  </view>
</view>