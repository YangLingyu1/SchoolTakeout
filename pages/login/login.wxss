.login-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  padding: 80rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.login-container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.logo-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 36rpx;
  border-radius: 50%;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.25);
  }
}

.app-title {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.app-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  width: 100%;
}

.login-btn {
  width: 100%;
  margin-bottom: 48rpx;
  background-color: #FFFFFF;
  color: #FF6B35;
  border: none;
  border-radius: 50rpx;
  padding: 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.25);
}

.rider-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rider-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.rider-btn {
  background-color: transparent;
  color: #FFFFFF;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50rpx;
  padding: 26rpx 56rpx;
  font-size: 30rpx;
  transition: all 0.3s ease;
}

.rider-btn:hover {
  background-color: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 1);
  transform: translateY(-2rpx);
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.footer-links {
  display: flex;
  align-items: center;
}

.link-text {
  font-size: 24rpx;
  color: #FFFFFF;
  text-decoration: underline;
  margin: 0 12rpx;
  transition: color 0.3s ease;
}

.link-text:hover {
  color: rgba(255, 255, 255, 0.8);
}

/* 加载动画 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  padding: 48rpx;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #FF6B35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* 响应式设计 */
@media (max-height: 800px) {
  .login-container {
    padding: 60rpx 40rpx;
  }
  
  .logo {
    width: 140rpx;
    height: 140rpx;
    margin-bottom: 28rpx;
  }
  
  .app-title {
    font-size: 52rpx;
    margin-bottom: 16rpx;
  }
  
  .app-subtitle {
    font-size: 28rpx;
  }
  
  .login-btn {
    padding: 28rpx;
    font-size: 32rpx;
  }
}

@media (max-height: 600px) {
  .login-container {
    padding: 40rpx 30rpx;
  }
  
  .logo {
    width: 120rpx;
    height: 120rpx;
    margin-bottom: 24rpx;
  }
  
  .app-title {
    font-size: 44rpx;
    margin-bottom: 12rpx;
  }
  
  .app-subtitle {
    font-size: 24rpx;
  }
  
  .login-btn {
    padding: 24rpx;
    font-size: 28rpx;
    margin-bottom: 36rpx;
  }
  
  .rider-btn {
    padding: 20rpx 48rpx;
    font-size: 26rpx;
  }
  
  .footer {
    margin-top: 60rpx;
  }
}