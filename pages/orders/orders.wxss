.orders-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 订单状态筛选 */
.order-tabs {
  display: flex;
  background-color: #FFFFFF;
  padding: 24rpx 0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.tab-item:hover {
  background-color: #f9f9f9;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  border-radius: 2rpx;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    width: 0;
  }
  to {
    width: 48rpx;
  }
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 600;
}

/* 订单列表 */
.orders-list {
  height: calc(100vh - 120rpx);
  padding: 24rpx;
}

.order-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  animation: fadeInUp 0.4s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.order-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.order-number {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.order-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.order-status {
  font-size: 28rpx;
  font-weight: 600;
}

.order-status.pending {
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.order-status.delivering {
  background: linear-gradient(90deg, #1890FF 0%, #40A9FF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.order-status.completed {
  background: linear-gradient(90deg, #52C41A 0%, #73D13D 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.delete-order {
  font-size: 24rpx;
  color: #999999;
  transition: all 0.3s ease;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.delete-order:hover {
  color: #FF4757;
  background-color: #FFF4E5;
}

/* 订单进度 */
.order-progress {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 12rpx;
}

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
}

.step-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
  position: relative;
}

.step.active .step-icon {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
  }
  50% {
    transform: scale(1.1);
    box-shadow: 0 6rpx 16rpx rgba(255, 107, 53, 0.4);
  }
}

.step-text {
  font-size: 24rpx;
  color: #999999;
  transition: all 0.3s ease;
}

.step.active .step-text {
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 600;
}

.step-line {
  height: 2rpx;
  background-color: #e0e0e0;
  flex: 1;
  margin: 0 16rpx;
  margin-top: 16rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  height: 3rpx;
}

/* 订单商品 */
.order-items {
  margin-bottom: 24rpx;
}

.item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.item:hover {
  background-color: #f9f9f9;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 8rpx;
}

.item:last-child {
  border-bottom: none;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease;
}

.item-image:hover {
  transform: scale(1.05);
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 4rpx;
  font-weight: 500;
  transition: color 0.3s ease;
}

.item-name:hover {
  color: #FF6B35;
}

.item-quantity {
  font-size: 24rpx;
  color: #999999;
}

.item-price {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 订单汇总 */
.order-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
  margin-bottom: 24rpx;
}

/* 订单地址信息 */
.order-address {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.address-label {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.address-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 8rpx;
  font-weight: 600;
}

.address-phone {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.address-detail {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.summary-text {
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.summary-price {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: bold;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 订单操作 */
.order-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.order-actions .btn-secondary {
  background-color: #FFFFFF;
  color: #666666;
  border: 2rpx solid #e0e0e0;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.order-actions .btn-secondary:hover {
  border-color: #FF6B35;
  color: #FF6B35;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.15);
}

.order-actions .btn-primary {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.order-actions .btn-primary:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-subtext {
  font-size: 24rpx;
  color: #cccccc;
}
