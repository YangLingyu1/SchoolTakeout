<view class="search-container">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-bar">
      <button wx:if="{{searchResults.length > 0}}" class="back-btn" bindtap="resetSearch">
        <text class="back-text">返回</text>
      </button>
      <input class="search-input" placeholder="搜索美食、商品..." bindinput="onSearchInput" value="{{searchKeyword}}" />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{searchResults.length > 0}}">
    <view class="result-item" wx:for="{{searchResults}}" wx:key="id" bindtap="goToProductDetail" data-id="{{item.id}}">
      <image class="result-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <text class="result-desc">{{item.description}}</text>
        <text class="result-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{searchHistory.length > 0 && searchResults.length === 0}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="clear-history" bindtap="clearSearchHistory">清空</text>
    </view>
    <view class="history-tags">
      <text class="history-tag" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onHistoryTagTap" data-keyword="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 热门搜索 -->
  <view class="hot-search" wx:if="{{hotSearch.length > 0 && searchResults.length === 0}}">
    <view class="hot-header">
      <text class="hot-title">热门搜索</text>
    </view>
    <view class="hot-tags">
      <text class="hot-tag" wx:for="{{hotSearch}}" wx:key="*this" bindtap="onHotTagTap" data-keyword="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 新品上市 -->
  <view class="new-products" wx:if="{{newProducts.length > 0 && searchResults.length === 0}}">
    <view class="new-header">
      <text class="new-title">新品上市</text>
    </view>
    <view class="new-grid">
      <view class="new-item" wx:for="{{newProducts}}" wx:key="id" bindtap="goToProductDetail" data-id="{{item.id}}">
        <image class="new-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <text class="new-name">{{item.name}}</text>
        <text class="new-price">¥{{item.price}}</text>
        <view class="new-badge">新品</view>
      </view>
    </view>
  </view>

  <!-- 推荐商品 -->
  <view class="recommend-section" wx:if="{{recommendProducts.length > 0 && searchResults.length === 0}}">
    <view class="recommend-header">
      <text class="recommend-title">{{recommendTitle}}</text>
    </view>
    <view class="recommend-grid">
      <view class="recommend-item" wx:for="{{recommendProducts}}" wx:key="id" bindtap="goToProductDetail" data-id="{{item.id}}">
        <image class="recommend-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <text class="recommend-name">{{item.name}}</text>
        <text class="recommend-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>

  <!-- 随机提示 -->
  <view class="tips-section">
    <text class="tips-text">{{randomTip}}</text>
  </view>
</view>