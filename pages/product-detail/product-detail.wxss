.product-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 商品图片 */
.product-images {
  height: 480rpx;
  background-color: #FFFFFF;
}

.image-swiper {
  height: 100%;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.product-info {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.product-header {
  margin-bottom: 32rpx;
}

.product-name {
  display: block;
  font-size: 40rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.product-price-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 48rpx;
  color: #FF6B35;
  font-weight: bold;
}

.product-stock {
  font-size: 28rpx;
  color: #999999;
}

.product-description {
  padding-top: 32rpx;
  border-top: 2rpx solid #f0f0f0;
}

.desc-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 购买操作 */
.purchase-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.quantity-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 48rpx;
}

.quantity-label {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.quantity-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  border: 2rpx solid #e0e0e0;
}

.quantity-btn.minus {
  background-color: #f9f9f9;
  color: #666666;
}

.quantity-btn.plus {
  background-color: #FF6B35;
  color: #FFFFFF;
  border-color: #FF6B35;
}

.quantity-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.quantity-text {
  font-size: 32rpx;
  color: #333333;
  min-width: 60rpx;
  text-align: center;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
}

.add-cart-btn {
  flex: 1;
  background-color: #FFFFFF;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.buy-now-btn {
  flex: 1;
  background-color: #FF6B35;
  color: #FFFFFF;
  border: none;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
}

/* 推荐区域 */
.recommend-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.recommend-header {
  margin-bottom: 24rpx;
}

.recommend-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.recommend-list {
  white-space: nowrap;
}

.recommend-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 24rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 16rpx;
}

.recommend-image {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.recommend-name {
  display: block;
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-price {
  display: block;
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}

/* 随机提示 */
.tips-section {
  background-color: #FFFFFF;
  padding: 32rpx;
  text-align: center;
}

.tips-text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 500;
}