.index-container {
  height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 200rpx;
  overflow: hidden;
}

/* 营业状态提示 */
.business-status {
  background-color: #FFF4E5;
  padding: 20rpx 32rpx;
  text-align: center;
  border-bottom: 2rpx solid #FFE0B2;
  position: relative;
  overflow: hidden;
}

.business-status::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 107, 53, 0.1), transparent);
  animation: shine 2s infinite;
}

@keyframes shine {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

.status-text {
  color: #FF6B35;
  font-size: 26rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

/* 夜间配送提示 */
.night-delivery-notice {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  padding: 20rpx 32rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.night-delivery-notice::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  animation: shine 2s infinite;
}

.notice-text {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 500;
  position: relative;
  z-index: 1;
}

/* 搜索栏 */
.search-section {
  background-color: #FFFFFF;
  padding: 24rpx 32rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 32rpx;
  transition: all 0.3s ease;
}

.search-bar:focus-within {
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
  transform: translateY(-2rpx);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
}

.search-input::placeholder {
  color: #999999;
  font-size: 28rpx;
}

.search-btn {
  background-color: #FF6B35;
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 12rpx 8rpx !important;
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  white-space: nowrap;
  width: 100rpx !important;
  min-width: 100rpx !important;
  line-height: 1.2;
}

.search-btn:hover {
  background-color: #FF8C5A;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

/* 搜索结果头部 */
.search-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #f0f0f0;
  animation: slideInDown 0.3s ease;
}

@keyframes slideInDown {
  from {
    transform: translateY(-20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.back-btn {
  background-color: #f5f5f5;
  color: #333333;
  border: none;
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.back-btn:hover {
  background-color: #e0e0e0;
  transform: translateY(-2rpx);
}

.search-result-text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

/* Banner轮播图 */
.banner-section {
  padding: 32rpx;
}

.banner-swiper {
  height: 360rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.banner-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.banner-image:hover {
  transform: scale(1.05);
}

/* 分类和商品 */
.content-section {
  display: flex;
  background-color: #FFFFFF;
  height: calc(100vh - 500rpx);
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.category-sidebar {
  width: 200rpx;
  background-color: #f9f9f9;
  border-right: 2rpx solid #e0e0e0;
  position: relative;
}

.category-item {
  padding: 32rpx 24rpx;
  text-align: center;
  border-bottom: 2rpx solid #e0e0e0;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.category-item:hover {
  background-color: #f0f0f0;
}

.category-item.active {
  background-color: #FFFFFF;
  color: #FF6B35;
  font-weight: 600;
  transform: translateX(4rpx);
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #FF6B35 0%, #FF8E53 100%);
  border-radius: 0 3rpx 3rpx 0;
}

.category-name {
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.category-item.active .category-name {
  font-size: 30rpx;
}

.product-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.product-item {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.product-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease;
}

.product-image:hover {
  transform: scale(1.05);
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  transition: color 0.3s ease;
}

.product-name:hover {
  color: #FF6B35;
}

.product-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: bold;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.quantity-btn.minus {
  background-color: #f0f0f0;
  color: #666666;
}

.quantity-btn.minus:hover {
  background-color: #e0e0e0;
  transform: scale(1.1);
}

.quantity-btn.plus {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: #FFFFFF;
}

.quantity-btn.plus:hover {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.quantity-text {
  font-size: 28rpx;
  color: #333333;
  min-width: 40rpx;
  text-align: center;
  font-weight: 500;
}

/* 购物车悬浮窗 */
.cart-float {
  position: fixed;
  bottom: 120rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C5A 100%);
  border-radius: 50rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 53, 0.3);
  z-index: 200;
  transition: all 0.3s ease;
  animation: slideInUp 0.3s ease;
}

.cart-float:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 53, 0.4);
}

.cart-icon {
  position: relative;
  margin-right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.cart-icon:hover {
  transform: scale(1.1);
}

.cart-icon image {
  width: 36rpx;
  height: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background-color: #FF4757;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
  min-width: 28rpx;
  text-align: center;
  font-weight: bold;
  border: 2rpx solid #FFFFFF;
  animation: pulse 2s infinite;
}

.cart-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 24rpx;
}

.cart-total {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.cart-fee {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.cart-checkout {
  background-color: #FFFFFF;
  color: #FF6B35;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.cart-checkout:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

/* 购物车详情弹窗 */
.cart-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 300;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s ease;
}

.cart-content {
  background-color: #FFFFFF;
  width: 100%;
  max-height: 85vh;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  border-radius: 32rpx 32rpx 0 0;
}

.cart-title {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.cart-clear {
  font-size: 28rpx;
  color: #FFFFFF;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.cart-clear:hover {
  background-color: rgba(255, 255, 255, 0.3);
  transform: translateY(-2rpx);
}

.cart-list {
  flex: 1;
  max-height: 450rpx;
  overflow-y: auto;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
  background-color: #FFFFFF;
  transition: all 0.3s ease;
}

.cart-item:hover {
  background-color: #f9f9f9;
  transform: translateX(4rpx);
}

.cart-item-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.cart-item-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 24rpx;
}

.cart-item-price {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: bold;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.cart-summary {
  padding: 32rpx;
  border-top: 2rpx solid #f0f0f0;
  background-color: #FAFAFA;
}

.summary-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666666;
}

.summary-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 0;
  padding-top: 28rpx;
  border-top: 2rpx solid #e0e0e0;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.total-price {
  font-size: 40rpx;
  color: #FF6B35;
  font-weight: bold;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8C5A 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.checkout-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
  transition: all 0.3s ease;
}

.checkout-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 53, 0.4);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .banner-swiper {
    height: 300rpx;
  }
  
  .product-image {
    width: 140rpx;
    height: 140rpx;
  }
  
  .product-name {
    font-size: 28rpx;
  }
  
  .cart-float {
    padding: 20rpx 24rpx;
  }
  
  .cart-total {
    font-size: 32rpx;
  }
}

/* 自定义滚动条 */
::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 随机Tips区域 */
.tips-section {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.08) 0%, rgba(255, 142, 83, 0.08) 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(255, 107, 53, 0.15);
  animation: fadeIn 0.5s ease;
}

.tips-header {
  margin-bottom: 16rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.tips-content {
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
