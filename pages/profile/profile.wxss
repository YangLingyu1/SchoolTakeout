.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 用户信息 */
.user-section {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  padding: 80rpx 32rpx 48rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.user-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.user-avatar:hover {
  transform: scale(1.05);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.25);
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 功能列表 */
.menu-section {
  padding-bottom: 120rpx;
}

.menu-group {
  background-color: #FFFFFF;
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.menu-group:hover {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
  transition: all 0.3s ease;
  cursor: pointer;
}

.menu-item:hover {
  background-color: #f9f9f9;
  padding-left: 40rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
  transition: color 0.3s ease;
}

.menu-item:hover .menu-text {
  color: #FF6B35;
}

.menu-value {
  font-size: 28rpx;
  color: #999999;
  margin-right: 16rpx;
  font-weight: 500;
}

.menu-arrow {
  width: 24rpx;
  height: 24rpx;
  transition: transform 0.3s ease;
}

.menu-item:hover .menu-arrow {
  transform: translateX(4rpx);
}

/* 退出登录 */
.logout-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 32rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.logout-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.2);
}

.logout-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

/* 响应式设计 */
@media (max-width: 375px) {
  .user-avatar {
    width: 100rpx;
    height: 100rpx;
  }
  
  .user-name {
    font-size: 36rpx;
  }
  
  .user-phone {
    font-size: 26rpx;
  }
  
  .menu-text {
    font-size: 28rpx;
  }
  
  .logout-btn {
    font-size: 28rpx;
    padding: 20rpx;
  }
}