.privacy-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  position: relative;
}

.back-btn {
  position: fixed;
  top: 40rpx;
  left: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.back-icon {
  width: 32rpx;
  height: 32rpx;
}

.privacy-content {
  padding: 30rpx;
}

.privacy-title {
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  margin-top: 60rpx;
}

.privacy-body {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.privacy-section {
  margin-bottom: 40rpx;
}

.privacy-section:last-child {
  margin-bottom: 0;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-bottom: 20rpx;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 15rpx;
}