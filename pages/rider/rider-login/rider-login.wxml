<view class="rider-login-container">
  <view class="login-card">
    <view class="login-header">
      <text class="login-title">骑手登录</text>
      <text class="login-subtitle">请输入您的手机号和姓名进行验证</text>
    </view>

    <view class="login-form">
      <view class="form-group">
        <text class="form-label">手机号</text>
        <input class="form-input" placeholder="请输入手机号" placeholder-style="color:#999999;font-size:26rpx" bindinput="onPhoneInput" value="{{phone}}" maxlength="11" />
      </view>

      <view class="form-group">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" placeholder-style="color:#999999;font-size:26rpx" bindinput="onNameInput" value="{{name}}" />
      </view>

      <view class="form-group">
        <text class="form-label">密码</text>
        <input class="form-input" placeholder="请输入密码" placeholder-style="color:#999999;font-size:26rpx" bindinput="onPasswordInput" value="{{password}}" type="password" />
      </view>

      <button class="login-btn" bindtap="onLogin" disabled="{{!canLogin}}">登录验证</button>
    </view>
  </view>

  <view class="login-tips">
    <text class="tips-text">登录后即可进入骑手中心</text>
  </view>

  <view class="register-section">
    <text class="register-text">还没有骑手账号？</text>
    <text class="register-link" bindtap="goToRegister">申请成为骑手</text>
  </view>
</view>