/* pages/rider/rider-profile/rider-profile.wxss */
.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
  position: relative;
}

.custom-nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  padding-top: var(--status-bar-height, 44rpx);
  z-index: 1000;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  padding-right: 60rpx;
}

.profile-content {
  padding: 30rpx;
  padding-top: 128rpx;
}

.profile-header {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C61 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #fff;
  margin-bottom: 20rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.level-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

.level-badge.normal {
  background: rgba(255, 255, 255, 0.3);
}

.level-badge.silver {
  background: linear-gradient(135deg, #C0C0C0 0%, #E8E8E8 100%);
  color: #333;
}

.level-badge.gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFEC8B 100%);
  color: #333;
}

.status-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-label {
  font-size: 28rpx;
  color: #fff;
  opacity: 0.9;
}

.status-toggle {
  display: flex;
  gap: 10rpx;
}

.status-btn {
  padding: 12rpx 30rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
  opacity: 0.6;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.status-btn.active {
  opacity: 1;
  background: #fff;
  color: #FF6B35;
  font-weight: bold;
}

.info-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.balance-section {
  margin-bottom: 30rpx;
}

.balance-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C61 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.balance-label {
  font-size: 24rpx;
  color: #fff;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.balance-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.payment-section {
  margin-bottom: 30rpx;
}

.payment-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.payment-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.payment-code {
  width: 300rpx;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
  background: #f5f5f5;
}

.payment-tip {
  font-size: 24rpx;
  color: #999;
}

.menu-section {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #999;
}

.logout-section {
  margin-top: 30rpx;
}

.logout-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #fff;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.logout-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.info-links {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.link-item {
  text-align: center;
  padding: 20rpx;
}

.link-text {
  font-size: 24rpx;
  color: #999;
}

.rider-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 16rpx rgba(255, 107, 53, 0.2);
  z-index: 9999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: bold;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}
