.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  min-height: 100vh;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.header {
  text-align: center;
  margin: 60rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.form {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: box-shadow 0.3s ease;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
  animation: slideInUp 0.5s ease;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form:hover {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-4rpx);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
  background: linear-gradient(90deg, #FF6B35 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.input {
  width: 100%;
  height: 90rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
  background-color: #fafafa;
}

.input:focus {
  border-color: #FF6B35;
  background-color: white;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.1);
  transform: translateY(-2rpx);
}

.upload-container {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: all 0.3s ease;
  background-color: #fafafa;
  position: relative;
  overflow: hidden;
}

.upload-container:hover {
  border-color: #FF6B35;
  background: linear-gradient(135deg, rgba(255, 107, 53, 0.05) 0%, rgba(255, 142, 83, 0.05) 100%);
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.15);
}

.upload-btn {
  width: 100%;
  height: 100%;
  background-color: transparent;
  border: none;
  font-size: 28rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.upload-btn::before {
  content: "";
  width: 70rpx;
  height: 70rpx;
  background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="%23FF6B35"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: transform 0.3s ease;
}

.upload-btn:hover::before {
  transform: scale(1.1);
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.uploaded-image:hover {
  transform: scale(1.02);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8E53 100%);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  border-radius: 16rpx;
  margin-top: 60rpx;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 53, 0.35);
  letter-spacing: 2rpx;
  position: relative;
  overflow: hidden;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s ease;
}

.submit-btn:hover::before {
  left: 100%;
}

.submit-btn:hover {
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transform: translateY(-4rpx);
}

.submit-btn:active {
  transform: translateY(0);
}

.submit-btn::after {
  border: none;
}

.submit-btn-hover {
  opacity: 0.9;
}

/* 占位符样式 */
.placeholder {
  color: #ccc;
  font-size: 26rpx;
}

/* 提示文本样式 */
.hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  padding-left: 4rpx;
  font-weight: 500;
}

/* 上传按钮 hover 效果 */
.upload-btn-hover {
  background-color: rgba(255, 107, 53, 0.05);
}

/* 底部提示 */
.footer {
  margin-top: 40rpx;
  text-align: center;
  padding-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .form {
    padding: 30rpx;
  }
  
  .title {
    font-size: 32rpx;
  }
  
  .input {
    height: 80rpx;
  }
  
  .upload-container {
    height: 200rpx;
  }
  
  .submit-btn {
    height: 90rpx;
    font-size: 32rpx;
    margin-top: 50rpx;
  }
  
  .form-item {
    margin-bottom: 30rpx;
  }
  
  .footer {
    margin-top: 30rpx;
    padding-bottom: 40rpx;
  }
  
  .footer-text {
    font-size: 22rpx;
  }
}