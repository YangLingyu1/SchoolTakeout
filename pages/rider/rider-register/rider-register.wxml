<!--pages/rider/rider-register/rider-register.wxml-->
<view class="container">
  <view class="header">
    <text class="title">骑手注册</text>
  </view>
  
  <form class="form">
    <!-- 姓名输入 -->
    <view class="form-item">
      <text class="label">姓名</text>
      <input 
        class="input" 
        placeholder="请输入真实姓名" 
        placeholder-class="placeholder" 
        bindinput="bindNameInput"
      />
    </view>
    
    <!-- 手机号输入 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input" 
        placeholder="请输入手机号码" 
        placeholder-class="placeholder" 
        type="number" 
        bindinput="bindPhoneInput"
      />
    </view>
    
    <!-- 密码设置 -->
    <view class="form-item">
      <text class="label">设置密码</text>
      <input 
        class="input" 
        placeholder="请设置6-20位密码" 
        placeholder-class="placeholder" 
        type="password" 
        bindinput="bindPasswordInput"
      />
      <text class="hint">密码长度6-20位，包含字母和数字</text>
    </view>
    
    <!-- 身份证号输入 -->
    <view class="form-item">
      <text class="label">身份证号</text>
      <input 
        class="input" 
        placeholder="请输入身份证号码" 
        placeholder-class="placeholder" 
        bindinput="bindIdNumberInput"
      />
      <text class="hint">请输入18位身份证号码</text>
    </view>
    
    <!-- 身份证人像面上传 -->
    <view class="form-item">
      <text class="label">身份证人像面</text>
      <view class="upload-container">
        <image 
          wx:if="{{idFrontUrl}}" 
          src="{{idFrontUrl}}" 
          class="uploaded-image"
          mode="aspectFill"
        />
        <button 
          wx:else 
          class="upload-btn" 
          bindtap="uploadIdFront"
          hover-class="upload-btn-hover"
        >
          点击上传
        </button>
      </view>
      <text class="hint">请上传清晰的身份证人像面照片</text>
    </view>
    
    <!-- 身份证国徽面上传 -->
    <view class="form-item">
      <text class="label">身份证国徽面</text>
      <view class="upload-container">
        <image 
          wx:if="{{idBackUrl}}" 
          src="{{idBackUrl}}" 
          class="uploaded-image"
          mode="aspectFill"
        />
        <button 
          wx:else 
          class="upload-btn" 
          bindtap="uploadIdBack"
          hover-class="upload-btn-hover"
        >
          点击上传
        </button>
      </view>
      <text class="hint">请上传清晰的身份证国徽面照片</text>
    </view>
    
    <!-- 提交按钮 -->
    <button 
      class="submit-btn" 
      bindtap="submitApplication"
      hover-class="submit-btn-hover"
    >
      提交申请
    </button>
  </form>
  
  <view class="footer">
    <text class="footer-text">提交后，我们将在24小时内完成审核</text>
  </view>
</view>