<!--pages/rider/delivery/delivery.wxml-->
<view class="delivery-container">
  <view class="custom-nav-bar">
    <view class="nav-back" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <view class="nav-title">配送中</view>
  </view>
  <view class="delivery-content">
    <view class="section-title">
      <text>配送中订单</text>
    </view>

    <view class="order-list" wx:if="{{orders.length > 0}}">
      <view class="order-item" wx:for="{{orders}}" wx:key="id">
        <view class="order-header">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status">配送中</text>
        </view>
        <view class="order-body">
          <view class="order-info">
            <text class="info-label">位置：</text>
            <text class="info-value">{{item.address}}</text>
          </view>
          <view class="order-info">
            <text class="info-label">名字：</text>
            <text class="info-value">{{item.name}}</text>
          </view>
          <view class="order-info">
            <text class="info-label">电话：</text>
            <text class="info-value">{{item.phone}}</text>
          </view>
          <view class="order-info">
            <text class="info-label">商品数：</text>
            <text class="info-value">{{item.itemCount}}件</text>
          </view>
          <view class="order-info">
            <text class="info-label">楼层数：</text>
            <text class="info-value">{{item.floor}}层</text>
          </view>
        </view>
        <view class="earnings-section">
          <text class="earnings-label">预计收益：</text>
          <text class="earnings-value">¥{{item.earnings}}</text>
          <text class="earnings-tip">（0.1元*楼层数 + 0.1元*商品数）</text>
        </view>
        <view class="order-footer">
          <button class="complete-btn" bindtap="completeOrder" data-id="{{item.id}}">完成配送</button>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-text">暂无配送中订单</text>
    </view>
  </view>

  <view class="rider-tab-bar">
      <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
        <image class="tab-icon" src="/images/index.png" mode="aspectFit"></image>
        <text class="tab-text">抢单</text>
      </view>
      <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
        <image class="tab-icon" src="/images/order.png" mode="aspectFit"></image>
        <text class="tab-text">配送</text>
      </view>
      <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
        <image class="tab-icon" src="/images/search.png" mode="aspectFit"></image>
        <text class="tab-text">统计</text>
      </view>
      <view class="tab-item {{currentTab === 3 ? 'active' : ''}}" bindtap="switchTab" data-index="3">
        <image class="tab-icon" src="/images/my.png" mode="aspectFit"></image>
        <text class="tab-text">我的</text>
      </view>
    </view>
</view>
